OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=omni_rag_collection
QDRANT_GRAPH_COLLECTION=omni_rag_collection
INDEX_SCHEMA_VERSION=2

GRAPH_TRAVERSAL_ENABLED=true
GRAPH_TRAVERSAL_DEPTH=1
GRAPH_TRAVERSAL_MAX_NODES=6

MEMORY_ENABLED=true
SESSION_MEMORY_TTL_SECONDS=1800
DEFAULT_USER_ID=local-user
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=omni_rag_local
POSTGRES_DSN=postgresql://omni_rag:omni_rag_local@postgres:5432/omni_rag
